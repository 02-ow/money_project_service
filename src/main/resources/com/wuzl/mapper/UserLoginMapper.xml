<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wuzl.mapper.UserLoginMapper">

    <select id="getUserInfo" resultType="com.wuzl.domain.PO.UserPO">
        SELECT a.username,a.password FROM user a
        WHERE a.username = #{username,jdbcType=VARCHAR}
    </select>
</mapper>